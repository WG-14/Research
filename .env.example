# All research inputs and outputs must be absolute paths outside this repository.
RESEARCH_DATA_ROOT=/var/lib/bithumb-research/datasets
RESEARCH_ARTIFACT_ROOT=/var/lib/bithumb-research/artifacts
RESEARCH_REPORT_ROOT=/var/lib/bithumb-research/reports
RESEARCH_CACHE_ROOT=/var/lib/bithumb-research/cache
RESEARCH_DB_PATH=/var/lib/bithumb-research/candles.sqlite

# Optional deterministic execution controls.
RESEARCH_MAX_WORKERS=1
RESEARCH_RANDOM_SEED=0
