# All research inputs and outputs must be absolute paths outside this repository.
RESEARCH_DATA_ROOT=/var/lib/market-research/datasets
RESEARCH_ARTIFACT_ROOT=/var/lib/market-research/artifacts
RESEARCH_REPORT_ROOT=/var/lib/market-research/reports
RESEARCH_CACHE_ROOT=/var/lib/market-research/cache
RESEARCH_EXPERIMENT_IDENTITY_REGISTRY_PATH=/var/lib/market-research/_registry/research_validate_experiment_identity.jsonl
RESEARCH_DB_PATH=/var/lib/market-research/candles.sqlite

# Optional deterministic execution controls.
RESEARCH_MAX_WORKERS=1
RESEARCH_RANDOM_SEED=0
