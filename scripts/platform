#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
cd "$root"

# These defaults are applied by the shell before Python starts. Strict
# reproduction rejects random hash seeding or multithreaded numeric backends;
# callers may supply another fixed PYTHONHASHSEED, but thread limits remain 1.
: "${PYTHONHASHSEED:=0}"
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
BLIS_NUM_THREADS=1
VECLIB_MAXIMUM_THREADS=1
export PYTHONHASHSEED OMP_NUM_THREADS OPENBLAS_NUM_THREADS MKL_NUM_THREADS
export NUMEXPR_NUM_THREADS BLIS_NUM_THREADS VECLIB_MAXIMUM_THREADS

configure_test_tmpdir() {
  test_tmpdir=${RESEARCH_TEST_TMPDIR:-${TMPDIR:-/tmp}}
  if [ ! -d "$test_tmpdir" ]; then
    echo "test temp directory does not exist: $test_tmpdir" >&2
    exit 78
  fi
  if ! RESEARCH_SOCKET_CHECK_ROOT="$test_tmpdir" python3 - <<'PY'
import os
import socket
import tempfile
from pathlib import Path

root = Path(os.environ["RESEARCH_SOCKET_CHECK_ROOT"])
with tempfile.TemporaryDirectory(prefix="market-research-af-unix-", dir=root) as tmp:
    listener = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        listener.bind(str(Path(tmp) / "listener.sock"))
    finally:
        listener.close()
PY
  then
    echo "test temp directory must support AF_UNIX sockets: $test_tmpdir" >&2
    echo "set RESEARCH_TEST_TMPDIR to a Linux filesystem path such as /tmp" >&2
    exit 78
  fi
  TMPDIR=$test_tmpdir
  TEMP=$test_tmpdir
  TMP=$test_tmpdir
  export TMPDIR TEMP TMP
}

case "${1:-}" in
  test-core|test-web|test-operations|test-all|test-browser|test-integration|verify-deployment)
    configure_test_tmpdir
    ;;
esac

case "${1:-}" in
  bootstrap)
    exec uv sync --all-packages --all-groups --frozen
    ;;
  test-core)
    exec uv run --package market-research pytest tests
    ;;
  test-web)
    exec uv run --package market-research-internal-web pytest apps/internal_web/tests
    ;;
  test-operations)
    exec uv run --package research-operations pytest services/research_operations/tests
    ;;
  test-all)
    "$0" test-core
    "$0" test-web
    exec "$0" test-operations
    ;;
  test-browser)
    exec uv run --package market-research-internal-web pytest -q \
      apps/internal_web/tests/test_browser_e2e.py
    ;;
  test-integration)
    : "${RESEARCH_OPS_TEST_DATABASE_URL:?RESEARCH_OPS_TEST_DATABASE_URL is required}"
    if [ "${INTERNAL_WEB_DATABASE_ENGINE:-}" != postgresql ]; then
      echo "INTERNAL_WEB_DATABASE_ENGINE=postgresql is required" >&2
      exit 78
    fi
    uv run --package market-research-internal-web pytest -q \
      apps/internal_web/tests/test_postgresql_integration_contract.py \
      apps/internal_web/tests/test_governance_postgresql_atomicity.py
    exec uv run --package research-operations pytest -q \
      services/research_operations/tests/test_postgresql_core.py
    ;;
  lint)
    exec uv run --package research-operations ruff check \
      src tests tools apps/internal_web/src apps/internal_web/tests \
      services/research_operations/src services/research_operations/tests
    ;;
  typecheck)
    typecheck_root=$(mktemp -d "${TMPDIR:-/tmp}/market-research-typecheck.XXXXXX")
    trap 'rm -rf "$typecheck_root"' EXIT HUP INT TERM
    export RESEARCH_DATA_ROOT="$typecheck_root/datasets"
    export RESEARCH_ARTIFACT_ROOT="$typecheck_root/artifacts"
    export RESEARCH_REPORT_ROOT="$typecheck_root/reports"
    export RESEARCH_CACHE_ROOT="$typecheck_root/cache"
    export RESEARCH_OPS_SOURCE_ROOT="$root"
    : "${INTERNAL_WEB_SECRET_KEY:=typecheck-only-not-for-runtime-use}"
    export INTERNAL_WEB_SECRET_KEY
    uv run --frozen --no-sync --package market-research mypy \
      --no-incremental --config-file pyproject.toml -p market_research
    uv run --frozen --no-sync --package market-research mypy \
      --no-incremental --config-file pyproject.toml \
      -p market_research_web -p portal
    uv run --frozen --no-sync --package market-research mypy \
      --no-incremental --config-file pyproject.toml -p research_operations
    uv run --frozen --no-sync --package market-research mypy \
      --no-incremental --config-file pyproject.toml \
      tools/reference_audit.py tools/reference_audit_surface.py \
      tools/update_reference_audit.py tools/render_reference_audit_report.py
    ;;
  compile)
    exec uv run --package market-research python -m compileall -q \
      src apps/internal_web/src services/research_operations/src
    ;;
  docs-check)
    uv run --package market-research python tools/check_dataset_dictionary.py
    uv run --package market-research-internal-web \
      python tools/check_internal_web_contracts.py
    exec uv run --package market-research python tools/check_documentation.py
    ;;
  verify-complete)
    shift
    uv run --frozen --no-sync --package market-research \
      python tools/update_reference_audit.py --check
    uv run --frozen --no-sync --package market-research \
      python tools/render_reference_audit_report.py --check
    exec uv run --frozen --no-sync --package market-research \
      python tools/reference_audit.py "$@"
    ;;
  verify-product-scope)
    shift
    exec uv run --frozen --no-sync --package market-research \
      python tools/platform_completeness.py "$@"
    ;;
  audit)
    requirements="${TMPDIR:-/tmp}/research-platform-runtime-requirements.txt"
    uv export --frozen --all-packages --no-dev --no-emit-workspace \
      --no-hashes --output-file "$requirements"
    exec uv run --no-sync pip-audit -r "$requirements" --progress-spinner off
    ;;
  build)
    exec uv run --frozen --no-sync --package market-research \
      python tools/build_release_artifacts.py \
      --output-dir "$root/dist/platform"
    ;;
  release-manifest)
    shift
    exec uv run --package market-research python tools/release_manifest.py "$@"
    ;;
  install-release)
    shift
    exec python3 tools/install_release.py "$@"
    ;;
  verify-deployment)
    exec uv run --package research-operations pytest -q \
      services/research_operations/tests/test_native_deployment.py
    ;;
  backup-restore-drill)
    shift
    exec uv run --package research-operations research-ops recovery-verify "$@"
    ;;
  research)
    shift
    exec uv run --frozen --package market-research market-research "$@"
    ;;
  *)
    echo "usage: scripts/platform {bootstrap|test-core|test-web|test-operations|test-all|test-browser|test-integration|lint|typecheck|compile|docs-check|verify-complete|verify-product-scope|audit|build|release-manifest|install-release|verify-deployment|backup-restore-drill|research}" >&2
    exit 64
    ;;
esac
