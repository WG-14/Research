# Copy to an operator-owned, mode-0600 environment file. Never commit values.
# Every image reference must include an immutable digest.
RESEARCH_OPS_IMAGE=registry.internal/research-operations@sha256:REPLACE_64_HEX
# Build-only: approved uv/Python base, also pinned by digest.
UV_PYTHON_IMAGE=ghcr.io/astral-sh/uv:0.11.2-python3.12-bookworm-slim@sha256:REPLACE_64_HEX
NGINX_IMAGE=docker.io/library/nginx@sha256:REPLACE_64_HEX
POSTGRES_IMAGE=docker.io/library/postgres@sha256:REPLACE_64_HEX

RESEARCH_OPS_RELEASE_ID=research-ops-2026.07.16.1
RESEARCH_OPS_BUILD_DIGEST=sha256:REPLACE_64_HEX
RESEARCH_OPS_EXPECTED_MIGRATION_DIGEST=sha256:GENERATE_WITH_RELEASE_VALIDATOR
RESEARCH_OPS_DEPLOYMENT_SCOPE=single-host
RESEARCH_OPS_SOURCE_ROOT=/opt/Research
RESEARCH_OPS_FILESYSTEM_QUALIFICATION_RECEIPT=/etc/research-ops/filesystem-qualification.json

POSTGRES_DB=research
POSTGRES_OWNER_USER=research_owner
POSTGRES_RUNTIME_USER=research_runtime
POSTGRES_DIAGNOSTICS_USER=research_diagnostics
POSTGRES_VALIDATOR_USER=research_validator
POSTGRES_BACKUP_USER=research_backup
POSTGRES_MAJOR=16

RESEARCH_DATA_ROOT=/srv/research/data
RESEARCH_ARTIFACT_ROOT=/srv/research/artifacts
RESEARCH_REPORT_ROOT=/srv/research/reports
RESEARCH_CACHE_ROOT=/srv/research/cache
RESEARCH_EXPERIMENT_IDENTITY_REGISTRY_PATH=/srv/research/registry/research_validate_experiment_identity.jsonl
INTERNAL_WEB_STATIC_ROOT=/srv/research/artifacts/_internal_web/static
RESEARCH_MAX_WORKERS=2
RESEARCH_RANDOM_SEED=0

INTERNAL_WEB_DATABASE_ENGINE=postgresql
INTERNAL_WEB_DATABASE_NAME=research
INTERNAL_WEB_DATABASE_HOST=postgres
INTERNAL_WEB_DATABASE_PORT=5432
INTERNAL_WEB_DATABASE_SSLMODE=verify-full
INTERNAL_WEB_DATABASE_SSLROOTCERT=/run/secrets/database_ca
INTERNAL_WEB_DATABASE_CONNECT_TIMEOUT_SECONDS=5
INTERNAL_WEB_DATABASE_STATEMENT_TIMEOUT_MS=30000
INTERNAL_WEB_DATABASE_LOCK_TIMEOUT_MS=5000
INTERNAL_WEB_DATABASE_IDLE_TRANSACTION_TIMEOUT_MS=30000
INTERNAL_WEB_DATABASE_CONN_MAX_AGE_SECONDS=60
INTERNAL_WEB_DATABASE_APPLICATION_NAME=market-research-web

INTERNAL_WEB_ALLOWED_HOSTS=research.internal.example
INTERNAL_WEB_CSRF_TRUSTED_ORIGINS=https://research.internal.example:8443
INTERNAL_WEB_TRUST_X_FORWARDED_PROTO=true
INTERNAL_WEB_SECURE_SSL_REDIRECT=true
INTERNAL_WEB_SECURE_COOKIES=true
INTERNAL_WEB_HSTS_SECONDS=3600
INTERNAL_WEB_HSTS_INCLUDE_SUBDOMAINS=false
INTERNAL_WEB_TIME_ZONE=Asia/Seoul
INTERNAL_WEB_AUDIT_SEGMENT_ROWS=10000

INTERNAL_WEB_MAX_PARAMETER_CANDIDATES=4096
INTERNAL_WEB_MAX_EXECUTION_SCENARIOS=32
INTERNAL_WEB_MAX_WORK_UNITS=32768
INTERNAL_WEB_LOGIN_FAILURE_LIMIT=5
INTERNAL_WEB_LOGIN_FAILURE_WINDOW_SECONDS=900
INTERNAL_WEB_LOGIN_BLOCK_SECONDS=900

RESEARCH_OPS_AUDIT_OBSERVATION_MAX_AGE_SECONDS=300
RESEARCH_OPS_OUTBOX_MAX_LAG_SECONDS=60
RESEARCH_OPS_WORKER_HEARTBEAT_MAX_AGE_SECONDS=30
RESEARCH_OPS_JOB_EXECUTION_TIMEOUT_SECONDS=21600
RESEARCH_OPS_JOB_CHILD_MEMORY_LIMIT_MB=2048
RESEARCH_OPS_JOB_CHILD_OUTPUT_LIMIT_BYTES=67108864
RESEARCH_OPS_JOB_CHILD_PROCESS_LIMIT=128
RESEARCH_OPS_MINIMUM_OUTBOX_WORKERS=1
RESEARCH_OPS_MINIMUM_RESEARCH_JOB_WORKERS=1
RESEARCH_OPS_HEALTH_CACHE_SECONDS=5
RESEARCH_OPS_BACKUP_MAX_AGE_SECONDS=90000
RESEARCH_OPS_RESTORE_DRILL_MAX_AGE_SECONDS=2678400

WEB_WORKERS=2
WEB_THREADS=2
OPS_API_WORKERS=2
EMPLOYEE_SERVER_NAME=research.internal.example
EMPLOYEE_BIND_ADDRESS=0.0.0.0
EMPLOYEE_HTTP_PORT=8080
EMPLOYEE_HTTPS_PORT=8443
OPS_BIND_ADDRESS=127.0.0.1
OPS_HTTPS_PORT=9443

# Absolute host paths. Data is read-only except the nested manifest bind.
RESEARCH_DATA_ROOT_HOST=/srv/research/data
RESEARCH_MANIFEST_ROOT_HOST=/srv/research/data/_internal_web/manifests
RESEARCH_ARTIFACT_ROOT_HOST=/srv/research/artifacts
RESEARCH_REPORT_ROOT_HOST=/srv/research/reports
RESEARCH_CACHE_ROOT_HOST=/srv/research/cache
RESEARCH_REGISTRY_ROOT_HOST=/srv/research/registry
RESEARCH_STATIC_ROOT_HOST=/srv/research/artifacts/_internal_web/static
RESEARCH_BACKUP_ROOT_HOST=/srv/research-backups
RESEARCH_RESTORE_ROOT_HOST=/srv/research-restore
FILESYSTEM_QUALIFICATION_RECEIPT_HOST=/etc/research-ops/filesystem-qualification.json

# Each secret path is an absolute, operator-controlled host file.
POSTGRES_OWNER_PASSWORD_FILE=/etc/research-ops/secrets/postgres-owner-password
POSTGRES_RUNTIME_PASSWORD_FILE=/etc/research-ops/secrets/postgres-runtime-password
POSTGRES_DIAGNOSTICS_PASSWORD_FILE=/etc/research-ops/secrets/postgres-diagnostics-password
POSTGRES_VALIDATOR_PASSWORD_FILE=/etc/research-ops/secrets/postgres-validator-password
POSTGRES_BACKUP_PASSWORD_FILE=/etc/research-ops/secrets/postgres-backup-password
DJANGO_SECRET_KEY_FILE=/etc/research-ops/secrets/django-secret-key
DATABASE_CA_FILE=/etc/research-ops/pki/ca.crt
DATABASE_SERVER_CERT_FILE=/etc/research-ops/pki/postgres.crt
DATABASE_SERVER_KEY_FILE=/etc/research-ops/pki/postgres.key
PROXY_SERVER_CERT_FILE=/etc/research-ops/pki/proxy.crt
PROXY_SERVER_KEY_FILE=/etc/research-ops/pki/proxy.key
OPS_CLIENT_CA_FILE=/etc/research-ops/pki/ca.crt
OPS_HTPASSWD_FILE=/etc/research-ops/secrets/ops.htpasswd
BACKUP_SIGNING_KEY_FILE=/etc/research-ops/secrets/backup-signing.key
BACKUP_VERIFICATION_KEY_FILE=/etc/research-ops/secrets/backup-signing.pub
CONTROL_DATABASE_URL_FILE=/etc/research-ops/secrets/control-database-url
RESEARCH_OPS_CONTROL_DATABASE_URL_FILE=/run/secrets/control_database_url
RESEARCH_OPS_BACKUP_SIGNING_KEY_FILE=/run/secrets/backup_signing_key
RESEARCH_OPS_BACKUP_VERIFICATION_KEY_FILE=/run/secrets/backup_verification_key
RESEARCH_OPS_ALERT_ENDPOINT_URL_FILE=/run/secrets/service_alert_endpoint_url
RESEARCH_OPS_DATABASE_STATEMENT_TIMEOUT_MS=30000
RESEARCH_OPS_DATABASE_LOCK_TIMEOUT_MS=5000
RESEARCH_OPS_DATABASE_IDLE_TRANSACTION_TIMEOUT_MS=30000
