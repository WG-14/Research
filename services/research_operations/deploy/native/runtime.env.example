# Official native systemd deployment. Copy to /etc/research-ops/runtime.env,
# replace every SET_REQUIRED/REPLACE value, chown root:research-ops, chmod 0640.
# systemd EnvironmentFile syntax applies: do not use shell substitutions.

RESEARCH_OPS_DEPLOYMENT_ENVIRONMENT=production
RESEARCH_RUNTIME_PROFILE=operated
RESEARCH_OPS_SERVICE_USER=research-ops
RESEARCH_OPS_SERVICE_GROUP=research-ops
RESEARCH_OPS_WEB_USER=research-web
RESEARCH_OPS_ENV_FILE=/etc/research-ops/runtime.env
RESEARCH_OPS_POSTGRES_USER=postgres
RESEARCH_OPS_POSTGRES_GROUP=postgres

# Seven independently reviewed operational assignments. Values are stable
# directory identities, not free-form secrets. Backup and recovery approver,
# and service and security owner, must be distinct.
RESEARCH_OPS_SERVICE_OWNER=SET_REQUIRED_SERVICE_OWNER
RESEARCH_OPS_SECURITY_OWNER=SET_REQUIRED_SECURITY_OWNER
RESEARCH_OPS_DATA_OWNER=SET_REQUIRED_DATA_OWNER
RESEARCH_OPS_ON_CALL_OWNER=SET_REQUIRED_ON_CALL
RESEARCH_OPS_INCIDENT_COMMANDER=SET_REQUIRED_INCIDENT_COMMANDER
RESEARCH_OPS_BACKUP_OWNER=SET_REQUIRED_BACKUP_OWNER
RESEARCH_OPS_RECOVERY_APPROVER=SET_REQUIRED_RECOVERY_APPROVER

# All runtime distributions and this manifest belong to one immutable commit.
RESEARCH_OPS_RELEASE_ID=SET_REQUIRED_RELEASE_ID
RESEARCH_OPS_GIT_SHA=REPLACE_40_HEX
RESEARCH_OPS_BUILD_DIGEST=sha256:REPLACE_64_HEX
RESEARCH_OPS_EXPECTED_MIGRATION_DIGEST=sha256:REPLACE_64_HEX
RESEARCH_OPS_LOCK_DIGEST=sha256:REPLACE_64_HEX
RESEARCH_OPS_DEPLOYMENT_DIGEST=sha256:REPLACE_64_HEX
RESEARCH_OPS_RELEASE_BUNDLE_DIGEST=sha256:REPLACE_64_HEX
RESEARCH_OPS_SOURCE_ROOT=/opt/research-platform/current
RESEARCH_OPS_RELEASE_MANIFEST=/opt/research-platform/current/release.json
RESEARCH_OPS_PREFLIGHT_RECEIPT=/run/research-operations-preflight/observation.json
RESEARCH_OPS_PREFLIGHT_MAX_AGE_SECONDS=90000
RESEARCH_OPS_DEPLOYMENT_SCOPE=single-host

POSTGRES_DB=research
POSTGRES_OWNER_USER=research_owner
POSTGRES_RUNTIME_USER=research_runtime
POSTGRES_DIAGNOSTICS_USER=research_diagnostics
POSTGRES_VALIDATOR_USER=research_validator
POSTGRES_BACKUP_USER=research_backup
POSTGRES_MAJOR=16
RESEARCH_OPS_POSTGRESQL_DROP_IN=/etc/postgresql/16/main/conf.d/90-research-operations.conf
RESEARCH_OPS_POSTGRESQL_HBA_FILE=/etc/research-ops/postgresql/pg_hba.conf

INTERNAL_WEB_DATABASE_ENGINE=postgresql
INTERNAL_WEB_DATABASE_NAME=research
INTERNAL_WEB_DATABASE_HOST=research-db.internal.example
INTERNAL_WEB_DATABASE_PORT=5432
INTERNAL_WEB_DATABASE_SSLMODE=verify-full
INTERNAL_WEB_DATABASE_SSLROOTCERT=/etc/research-ops/pki/database-ca.crt
INTERNAL_WEB_DATABASE_CONNECT_TIMEOUT_SECONDS=5
INTERNAL_WEB_DATABASE_STATEMENT_TIMEOUT_MS=30000
INTERNAL_WEB_DATABASE_LOCK_TIMEOUT_MS=5000
INTERNAL_WEB_DATABASE_IDLE_TRANSACTION_TIMEOUT_MS=30000
INTERNAL_WEB_DATABASE_CONN_MAX_AGE_SECONDS=60
INTERNAL_WEB_DATABASE_APPLICATION_NAME=market-research-web
RESEARCH_OPS_DATABASE_STATEMENT_TIMEOUT_MS=30000
RESEARCH_OPS_DATABASE_LOCK_TIMEOUT_MS=5000
RESEARCH_OPS_DATABASE_IDLE_TRANSACTION_TIMEOUT_MS=30000

DJANGO_SETTINGS_MODULE=market_research_web.settings
INTERNAL_WEB_ALLOWED_HOSTS=research.internal.example
INTERNAL_WEB_CSRF_TRUSTED_ORIGINS=https://research.internal.example
INTERNAL_WEB_TRUST_X_FORWARDED_PROTO=true
INTERNAL_WEB_SECURE_SSL_REDIRECT=true
INTERNAL_WEB_SECURE_COOKIES=true
INTERNAL_WEB_HSTS_SECONDS=31536000
INTERNAL_WEB_HSTS_INCLUDE_SUBDOMAINS=false
INTERNAL_WEB_TIME_ZONE=Asia/Seoul
INTERNAL_WEB_AUDIT_SEGMENT_ROWS=10000
INTERNAL_WEB_MAX_PARAMETER_CANDIDATES=4096
INTERNAL_WEB_MAX_EXECUTION_SCENARIOS=32
INTERNAL_WEB_MAX_WORK_UNITS=32768
INTERNAL_WEB_LOGIN_FAILURE_LIMIT=5
INTERNAL_WEB_LOGIN_FAILURE_WINDOW_SECONDS=900
INTERNAL_WEB_LOGIN_BLOCK_SECONDS=900

RESEARCH_DATA_ROOT=/srv/research/data
RESEARCH_ARTIFACT_ROOT=/srv/research/artifacts
RESEARCH_REPORT_ROOT=/srv/research/reports
RESEARCH_CACHE_ROOT=/srv/research/cache
RESEARCH_EXPERIMENT_IDENTITY_REGISTRY_PATH=/srv/research/registry/research_validate_experiment_identity.jsonl
INTERNAL_WEB_STATIC_ROOT=/srv/research/artifacts/_internal_web/static
RESEARCH_OPS_FILESYSTEM_QUALIFICATION_RECEIPT=/etc/research-ops/filesystem-qualification.json
RESEARCH_MAX_WORKERS=2
RESEARCH_RANDOM_SEED=0

RESEARCH_OPS_AUDIT_OBSERVATION_MAX_AGE_SECONDS=300
RESEARCH_OPS_AUDIT_VALIDATION_INTERVAL_SECONDS=60
RESEARCH_OPS_OUTBOX_MAX_LAG_SECONDS=60
RESEARCH_OPS_WORKER_HEARTBEAT_MAX_AGE_SECONDS=30
RESEARCH_OPS_MINIMUM_OUTBOX_WORKERS=2
RESEARCH_OPS_MINIMUM_RESEARCH_JOB_WORKERS=1
RESEARCH_OPS_HEALTH_CACHE_SECONDS=5
RESEARCH_OPS_BACKUP_MAX_AGE_SECONDS=90000
RESEARCH_OPS_RESTORE_DRILL_MAX_AGE_SECONDS=2678400
WEB_WORKERS=2
WEB_THREADS=2
OPS_API_WORKERS=2

EMPLOYEE_SERVER_NAME=research.internal.example
RESEARCH_OPS_NGINX_CONFIG_FILE=/etc/nginx/conf.d/research-operations.conf
RESEARCH_OPS_PKI_MINIMUM_VALIDITY_SECONDS=2592000
PROXY_SERVER_CA_FILE=/etc/research-ops/pki/proxy-ca.crt
PROXY_SERVER_CERT_FILE=/etc/research-ops/pki/proxy.crt
PROXY_SERVER_KEY_FILE=/etc/research-ops/pki/proxy.key
OPS_CLIENT_CA_FILE=/etc/research-ops/pki/ops-client-ca.crt
DATABASE_CA_FILE=/etc/research-ops/pki/database-ca.crt
DATABASE_SERVER_CERT_FILE=/etc/research-ops/pki/postgres.crt
DATABASE_SERVER_KEY_FILE=/etc/research-ops/pki/postgres.key

# Secret files contain exactly one value and no trailing metadata. Keep all
# private files outside Git; mode 0600 research-ops:research-ops or mode 0640
# root:research-ops. PostgreSQL and proxy server keys follow their documented
# postgres/root ownership instead.
POSTGRES_OWNER_PASSWORD_FILE=/etc/research-ops/secrets/postgres-owner-password
POSTGRES_RUNTIME_PASSWORD_FILE=/etc/research-ops/secrets/postgres-runtime-password
POSTGRES_DIAGNOSTICS_PASSWORD_FILE=/etc/research-ops/secrets/postgres-diagnostics-password
POSTGRES_VALIDATOR_PASSWORD_FILE=/etc/research-ops/secrets/postgres-validator-password
POSTGRES_BACKUP_PASSWORD_FILE=/etc/research-ops/secrets/postgres-backup-password
DJANGO_SECRET_KEY_FILE=/etc/research-ops/secrets/django-secret-key
OPS_HTPASSWD_FILE=/etc/research-ops/secrets/ops.htpasswd
BACKUP_SIGNING_KEY_FILE=/etc/research-ops/secrets/backup-signing.key
BACKUP_VERIFICATION_KEY_FILE=/etc/research-ops/secrets/backup-signing.pub
CONTROL_DATABASE_URL_FILE=/etc/research-ops/secrets/control-database-url
RESEARCH_OPS_CONTROL_DATABASE_URL_FILE=/etc/research-ops/secrets/control-database-url
RESEARCH_OPS_BACKUP_SIGNING_KEY_FILE=/etc/research-ops/secrets/backup-signing.key
RESEARCH_OPS_BACKUP_VERIFICATION_KEY_FILE=/etc/research-ops/secrets/backup-signing.pub
RESEARCH_OPS_OFFSITE_RECEIPT_VERIFICATION_KEY_FILE=/etc/research-ops/offsite-receipt-signing.pub
# Root-only source copied by systemd only into the admitted worker's credential mount.
RESEARCH_OPS_EXECUTION_CAPABILITY_KEY_SOURCE_FILE=/etc/research-ops/secrets/operated-execution.key

# A production start is rejected unless an externally installed, root-owned
# executable hook and explicit encrypted off-site destination are configured.
BACKUP_ROOT=/srv/research-backups
RESEARCH_OPS_BACKUP_RUNTIME_DIRECTORY=/run/research-operations
BACKUP_OPERATOR_ID=systemd-scheduled-backup
RESEARCH_OPS_OFFSITE_REQUIRED=true
RESEARCH_OPS_OFFSITE_EXPORT_HOOK=/usr/local/libexec/research-ops-offsite-export
RESEARCH_OPS_OFFSITE_TARGET_ID=SET_REQUIRED_OFFSITE_TARGET
RESEARCH_OPS_OFFSITE_RECEIPT_ROOT=/srv/research-offsite-receipts
RESEARCH_OPS_BACKUP_ENCRYPTION=SET_REQUIRED_age_OR_kms-envelope
RESEARCH_OPS_BACKUP_ENCRYPTION_KEY_ID=SET_REQUIRED_EXTERNAL_KEY_ID
RESEARCH_OPS_BACKUP_RETENTION_DAYS=35
RESEARCH_OPS_BACKUP_RETENTION_MINIMUM_COUNT=7
RESEARCH_OPS_LEGAL_HOLD_ENFORCEMENT=true
RESEARCH_OPS_RPO_SECONDS=86400
RESEARCH_OPS_RTO_SECONDS=14400
