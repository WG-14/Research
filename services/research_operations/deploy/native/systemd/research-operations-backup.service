[Unit]
Description=Research Operations coherent signed backup and off-site export
Documentation=file:/opt/research-platform/current/services/research_operations/deploy/native/README.md
Requires=research-operations-preflight.service research-operations-migrate.service
Requires=research-operations-outbox-worker@1.service research-operations-outbox-worker@2.service
Requires=research-operations-job-worker.service research-operations-validator.service
After=research-operations-preflight.service research-operations-migrate.service
After=research-operations-outbox-worker@1.service research-operations-outbox-worker@2.service
After=research-operations-job-worker.service research-operations-validator.service

[Service]
Type=oneshot
User=research-ops
Group=research-ops
WorkingDirectory=/opt/research-platform/current
EnvironmentFile=/etc/research-ops/runtime.env
Environment=RESEARCH_OPS_DATABASE_ROLE=backup
Environment=RESEARCH_OPS_BACKUP_RUNTIME_DIRECTORY=/run/research-operations
Environment=PATH=/opt/research-platform/current/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/usr/bin/env /opt/research-platform/current/services/research_operations/scripts/runtime-entrypoint.py /bin/sh /opt/research-platform/current/services/research_operations/deploy/native/bin/native-backup.sh
KillSignal=SIGTERM
KillMode=control-group
TimeoutStartSec=90min
TimeoutStopSec=5min
UMask=0077
RuntimeDirectory=research-operations
RuntimeDirectoryMode=0700
RuntimeDirectoryPreserve=yes
NoNewPrivileges=true
CapabilityBoundingSet=
AmbientCapabilities=
PrivateTmp=true
PrivateDevices=true
ProtectSystem=strict
ProtectHome=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectControlGroups=true
ProtectClock=true
RestrictNamespaces=true
RestrictSUIDSGID=true
LockPersonality=true
MemoryDenyWriteExecute=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
SystemCallArchitectures=native
ReadOnlyPaths=/srv/research/data /srv/research/artifacts /srv/research/reports /srv/research/registry
ReadWritePaths=/srv/research-backups /srv/research-offsite-receipts /run/research-operations
TasksMax=64
LimitNOFILE=4096
MemoryMax=2G
CPUQuota=200%
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=6
StandardOutput=journal
StandardError=journal
SyslogIdentifier=research-operations-backup
